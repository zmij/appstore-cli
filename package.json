{
  "name": "appstore-flow",
  "version": "1.0.0",
  "description": "App Store Connect from your terminal — manage iOS listings, IAPs, subscriptions, and screenshots from YAML files. CLI + bundled MCP server.",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "appstore": "./build/index.js",
    "appstore-mcp": "./build/mcp/server.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "npm run build && npm run start",
    "watch": "tsc --watch",
    "docs:llms": "node scripts/build-llms-full.mjs",
    "docs:dev": "npm run docs:llms && vitepress dev docs",
    "docs:build": "npm run docs:llms && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "appstore",
    "app-store-connect",
    "ios",
    "apple",
    "metadata",
    "screenshots",
    "iap",
    "subscriptions",
    "mcp"
  ],
  "author": "Sergei Fedorov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zmij/appstore-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zmij/appstore-cli/issues"
  },
  "homepage": "https://github.com/zmij/appstore-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "appstore-connect-sdk": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.0.0",
    "image-size": "^2.0.2",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
