{
  "name": "appstore-cli",
  "version": "1.0.0",
  "description": "CLI + MCP server for managing App Store Connect metadata, screenshots, and in-app purchases",
  "type": "module",
  "bin": {
    "appstore": "./build/index.js",
    "appstore-mcp": "./build/mcp/server.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "npm run build && npm run start",
    "watch": "tsc --watch"
  },
  "keywords": [
    "appstore",
    "app-store-connect",
    "ios",
    "apple",
    "metadata",
    "screenshots",
    "iap",
    "subscriptions",
    "mcp"
  ],
  "author": "Sergei Fedorov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zmij/appstore-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zmij/appstore-cli/issues"
  },
  "homepage": "https://github.com/zmij/appstore-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "appstore-connect-sdk": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.0.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
