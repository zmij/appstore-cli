{
  "name": "appstore-cli",
  "version": "1.0.0",
  "description": "CLI tool for managing App Store Connect metadata, screenshots, and in-app purchases",
  "type": "module",
  "bin": {
    "appstore": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "npm run build && npm run start",
    "watch": "tsc --watch"
  },
  "keywords": [
    "appstore",
    "app-store-connect",
    "ios",
    "apple",
    "metadata",
    "screenshots"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "appstore-connect-sdk": "^2.0.0",
    "commander": "^12.0.0",
    "yaml": "^2.3.0",
    "chalk": "^5.3.0",
    "glob": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
